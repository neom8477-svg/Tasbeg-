<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textColor="@color/textPrimary"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/countText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="96sp"
        android:textColor="@color/counterColor"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toTopOf="@id/dhikrText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/dhikrText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dhikr_subhanallah"
        android:textSize="18sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/countText"
        app:layout_constraintBottom_toTopOf="@id/countButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/countButton"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="60dp"
        android:text="@string/tap"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/counterColor"
        android:elevation="8dp"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/dhikrText"
        app:layout_constraintBottom_toTopOf="@id/targetLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/targetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/target"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/target33"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/target33"
        style="@style/TargetButton"
        android:text="33"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@id/target99"
        app:layout_constraintEnd_toStartOf="@id/target99"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/target99" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/target99"
        style="@style/TargetButton"
        android:text="99"
        app:layout_constraintBottom_toTopOf="@id/resetButton"
        app:layout_constraintEnd_toStartOf="@id/target100"
        app:layout_constraintStart_toEndOf="@id/target33"
        app:layout_constraintTop_toTopOf="@id/target33" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/target100"
        style="@style/TargetButton"
        android:text="100"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="@id/target99"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/target99"
        app:layout_constraintTop_toTopOf="@id/target99" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/resetButton"
        style="@style/ResetButton"
        android:text="@string/reset"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>